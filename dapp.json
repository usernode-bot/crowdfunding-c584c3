{
  "name": "Community Fund",
  "secrets": [
    {
      "key": "APP_PUBKEY",
      "description": "The single wallet address that receives every app transaction (campaign creates, contributions). All on-chain state is reconstructed by polling transactions sent to this address.",
      "required": false,
      "private": false,
      "default": "ut1zr6s9h8gjq6wsllja4krwjxc8eek4yd9cntzzty9lq42zqrrtx5s47fwcr",
      "staging_default": "ut1zr6s9h8gjq6wsllja4krwjxc8eek4yd9cntzzty9lq42zqrrtx5s47fwcr"
    },
    {
      "key": "APP_SECRET_KEY",
      "description": "The private signing key (wallet seed) for APP_PUBKEY. Used by the server to sign transactions from the app's receiving wallet.",
      "required": false,
      "private": true,
      "staging_default": "utsk17aaq27yc2p4ts6lqcra0drftkf2ef338v6q3xyyq7h9hg6lczsrqtzvw2x"
    },
    {
      "key": "SENDER_APP_PUBKEY",
      "description": "The public key of the server-side wallet used to send withdraw and refund transactions back to users. Can be the same as APP_PUBKEY.",
      "required": false,
      "private": false,
      "default": "ut1zr6s9h8gjq6wsllja4krwjxc8eek4yd9cntzzty9lq42zqrrtx5s47fwcr",
      "staging_default": "ut1zr6s9h8gjq6wsllja4krwjxc8eek4yd9cntzzty9lq42zqrrtx5s47fwcr"
    },
    {
      "key": "SENDER_APP_SECRET_KEY",
      "description": "The private signing key (wallet seed) for SENDER_APP_PUBKEY. Used by the server to sign withdraw/refund transactions.",
      "required": false,
      "private": true,
      "staging_default": "utsk17aaq27yc2p4ts6lqcra0drftkf2ef338v6q3xyyq7h9hg6lczsrqtzvw2x"
    },
    {
      "key": "CHAIN_ID",
      "description": "Chain ID for the Usernode block explorer (e.g. 1 for mainnet). Used by the poller to look up transactions.",
      "required": false,
      "private": false,
      "staging_default": "1"
    }
  ],
  "tests": [
    { "name": "Discover loads", "path": "/#/", "expectSelector": ".campaign-grid, .empty-state" },
    { "name": "Create form renders", "path": "/#/create", "expectSelector": "form" },
    { "name": "My Sends renders", "path": "/#/sends", "expectSelector": ".sends-list, .empty-state" },
    { "name": "My Profile renders", "path": "/#/profile", "expectSelector": ".profile-view" },
    { "name": "My Received renders", "path": "/#/received", "expectSelector": ".received-list" }
  ]
}
